# Airtable Configuration
# Get your API key from: https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXX

# Get your Base ID from the Airtable URL
# Example: https://airtable.com/appABCDEF12345/tblXYZ123/viwXYZ
# Base ID is the part that starts with "app"
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name (case-sensitive, must match exactly)
AIRTABLE_TABLE_NAME=Jobs

# Server Configuration
PORT=3000
NODE_ENV=production
